{{!--
  PRODUCTION TEMPLATE: category_page.hbs
  Source: actual_theme/templates/category_page.hbs

  REMOVED FROM COPENHAGEN:
  - container-divider and container wrapper
  - sub-nav with breadcrumbs and scoped search
  - category-container with page-header (h1, description)
  - section-tree with sections, article-list, see-all-articles, more_articles
  - SVG icons for promoted/lock/star

  ADDED FROM PRODUCTION:
  - Custom search hero section (c-simple-search)
  - Custom breadcrumbs (c-breadcrumb-wrapper)
  - Custom category content area with accordion for internal agent portal (category id 33003929573650)
  - Standard layout with sections, article-list for all other categories
  - NOTE: CSS styles moved to SCSS files (breadcrumb, search, category, accordion)
--}}

<section class="category-page">

  {{!-- 1. SEARCH SECTION --}}
<section class="c-simple-search c-simple-search--white c-simple-search--green">
  <h1 class="c-simple-search__title">{{dc 'search_title'}}</h1>
  <div class="c-simple-search__form">
    {{search submit=true instant=true placeholder='Search by question, product'}}
  </div>
</section>

  {{!-- 2. BREADCRUMBS --}}
  <section class="c-breadcrumb-wrapper">
    <div class="c-container">
      {{breadcrumbs}}
    </div>
  </section>

  {{!-- 3. CATEGORY CONTENT --}}
  <section class="c-category__content page-content">
    <section class="clearfix">

      {{#is category.id 33003929573650}}

        <h1 class="c-category-body-title">Internal Agent Portal</h1>
        <p class="c-desc c-desc--center">Navigate to the sections below to find internal articles.</p>

        {{!-- Container filled by JavaScript --}}
        <div class="c-accordion" id="portalAccordion">
          <p class="c-accordion__loading">Loading sections…</p>
        </div>

        <script>
          (function () {
            var CATEGORY_ID = '33003929573650';
            var localeMatch = window.location.pathname.match(/\/hc\/([^/]+)\//);
            var locale = localeMatch ? localeMatch[1] : 'en-us';
            var baseUrl = '/api/v2/help_center/' + locale;
            var accordion = document.getElementById('portalAccordion');

            function fetchAll(url) {
              var results = [];
              function getPage(pageUrl) {
                return fetch(pageUrl).then(function (r) {
                  if (r.status === 404) return { sections: [], articles: [] };
                  if (!r.ok) throw new Error('HTTP ' + r.status + ' for ' + pageUrl);
                  return r.json();
                }).then(function (data) {
                  var items = data.sections || data.articles || [];
                  results = results.concat(items);
                  if (data.next_page) return getPage(data.next_page);
                  return results;
                });
              }
              return getPage(url);
            }

            function esc(text) {
              var d = document.createElement('div');
              d.appendChild(document.createTextNode(text));
              return d.innerHTML;
            }

            function articleLink(a, level) {
              return '<a href="' + a.html_url + '" class="c-accordion__article c-accordion__article--l' + level + '">' + esc(a.title) + '</a>';
            }

            function accordionItem(name, innerHtml, level) {
              if (!innerHtml) {
                return '<div class="c-accordion__item c-accordion__item--l' + level + '">' +
                    '<div class="c-accordion__empty c-accordion__empty--l' + level + '">' + esc(name) + '</div>' +
                '</div>';
              }
              return '<div class="c-accordion__item c-accordion__item--l' + level + '">' +
                '<button class="c-accordion__trigger c-accordion__trigger--l' + level + '" type="button" aria-expanded="false">' +
                  '<span class="c-accordion__label">' + esc(name) + '</span>' +
                  '<span class="c-accordion__chevron"></span>' +
                '</button>' +
                '<div class="c-accordion__panel" hidden>' + innerHtml + '</div>' +
              '</div>';
            }

            fetchAll(baseUrl + '/categories/' + CATEGORY_ID + '/sections.json?per_page=100')
              .then(function (allSections) {
                var childrenOf = {};
                allSections.forEach(function (s) {
                  var parentKey = s.parent_section_id || 'root';
                  if (!childrenOf[parentKey]) childrenOf[parentKey] = [];
                  childrenOf[parentKey].push(s);
                });
                var topSections = childrenOf['root'] || [];
                var allIds = allSections.map(function (s) { return s.id; });
                var articlePromises = allIds.map(function (id) {
                  return fetchAll(baseUrl + '/sections/' + id + '/articles.json?per_page=100')
                    .then(function (articles) { return { id: id, articles: articles }; });
                });
                return Promise.all(articlePromises).then(function (results) {
                  var articlesOf = {};
                  results.forEach(function (r) { articlesOf[r.id] = r.articles; });
                  return { topSections: topSections, childrenOf: childrenOf, articlesOf: articlesOf };
                });
              })
              .then(function (data) {
                function buildSection(section, level) {
                  var inner = '';
                  var children = data.childrenOf[section.id] || [];
                  var articles = data.articlesOf[section.id] || [];
                  children.forEach(function (child) {
                    inner += buildSection(child, level + 1);
                  });
                  articles.forEach(function (a) {
                    inner += articleLink(a, level + 1);
                  });
                  return accordionItem(section.name, inner, level);
                }
                var html = '';
                data.topSections.forEach(function (section) {
                  html += buildSection(section, 1);
                });
                accordion.innerHTML = html || '<p style="text-align:center;color:#666;">No sections found.</p>';
                bindAccordion();
              })
              .catch(function (err) {
                console.error('[Portal] Error:', err);
                accordion.innerHTML = '<p style="color:red;text-align:center;">Failed to load sections. Please refresh the page.</p>';
              });

            function bindAccordion() {
              var triggers = accordion.querySelectorAll('.c-accordion__trigger');
              for (var i = 0; i < triggers.length; i++) {
                triggers[i].addEventListener('click', function () {
                  var panel = this.nextElementSibling;
                  var isOpen = this.getAttribute('aria-expanded') === 'true';
                  this.setAttribute('aria-expanded', String(!isOpen));
                  panel.hidden = isOpen;
                });
              }
            }
          })();
        </script>

      {{else}}

        {{!-- STANDARD LAYOUT — All other categories --}}
        <h1 class="c-category-body-title">{{category.name}}</h1>

        {{#if category.description}}
          <p class="c-desc c-desc--center">{{category.description}}</p>
        {{/if}}

        {{#if category.sections}}
          <div class="c-category__content-tree">
            {{#each sections}}
              <section class="section" data-toggle-category>
                <h3>
                  <a href="{{url}}">{{name}}</a>
                </h3>
                {{#if articles}}
                  <ul class="article-list">
                    {{#each articles}}
                      <li {{#if promoted}} class="article-promoted" {{/if}}>
                        {{#if promoted}}
                          <span data-title="{{t 'promoted'}}">★</span>
                        {{/if}}
                        <a href="{{url}}">{{title}}</a>
                      </li>
                    {{/each}}
                  </ul>
                {{/if}}
              </section>
            {{/each}}
          </div>
        {{/if}}

      {{/is}}

    </section>
  </section>
</section>

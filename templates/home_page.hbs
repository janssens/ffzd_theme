{{!--
  PRODUCTION TEMPLATE: home_page.hbs
  Source: actual_theme/templates/home_page.hbs

  REMOVED FROM COPENHAGEN:
  - hero section with search icon SVG and instant search
  - container with knowledge-base section, categories blocks-list, promoted_articles
  - community section with join_conversation link and community-image
  - recent_activity section

  ADDED FROM PRODUCTION:
  - Hero/search section with Fairphone branding (c-simple-search)
  - Issue diagnose CTA section with b2x.com links
  - Knowledge base categories in 2x2 grid with icons
  - Contact support section with chat and email cards
  - Zingtree script
  - NOTE: CSS styles moved to SCSS files (buttons, search, home-articles, home)
--}}


{{!-- ============================================
  SECTION 1: HERO / SEARCH
  White background, grey search bar, Green Search Button
============================================ --}}
<section class="c-simple-search c-simple-search--white">
  <h1 class="c-simple-search__title">{{dc 'hero_title'}}</h1>
  <div class="c-simple-search__form">
   {{search submit=true instant=true placeholder='Search by question, product'}}
  </div>
</section>

{{!-- ============================================
  SECTION 2: ISSUE DIAGNOSE CTA
============================================ --}}
<section class="c-issue-diagnose">
  <div class="c-issue-diagnose__inner">
    <h2 class="c-issue-diagnose__title">{{dc 'issue_container_title'}}</h2>
    <p class="c-issue-diagnose__text">{{dc 'issue_container_paragraph'}}</p>
    <div class="c-issue-diagnose__links">
      <a href="https://fairphone.b2x.com/troubleshooting" class="c-btn-secondary">
        {{dc 'issue_diagnose_button'}} →
      </a>
      <a href="https://fairphone.b2x.com/track" class="c-issue-diagnose__secondary-link">
        {{dc 'issue_track_repair_link'}} →
      </a>
    </div>
  </div>
</section>

<section class="c-container">

  {{!-- ============================================
    SECTION 3: KNOWLEDGE BASE / CATEGORIES
    2x2 Grid layout
  ============================================ --}}
  <section class="c-home-articles">
    <h2 class="c-home-articles__title">{{dc 'knowledge_base_explore_title'}}</h2>
    <div class="c-home-articles__inner c-home-articles__inner--grid-2x2">
      
      {{!-- Row 1: How to use your product (top-left) --}}
      {{#each categories}}
        {{#is id 31678993164306}}
        <a class="c-home-articles__item c-home-articles__item--with-icon" href="{{url}}">
          <div class="c-home-articles__item-icon">
            <img src="{{asset 'svg/spareparts.svg'}}" alt="">
          </div>
          <h4 class="c-home-articles__item-title">{{name}}</h4>
          {{#if description}}
          <span class="c-home-articles__item-desc">{{excerpt description}}</span>
          {{/if}}
        </a>
        {{/is}}
      {{/each}}
      
      {{!-- Row 1: Account and orders (top-right) --}}
      {{#each categories}}
        {{#is id 31678813783954}}
        <a class="c-home-articles__item c-home-articles__item--with-icon" href="{{url}}">
          <div class="c-home-articles__item-icon">
            <img src="{{asset 'svg/protect.svg'}}" alt="">
          </div>
          <h4 class="c-home-articles__item-title">{{name}}</h4>
          {{#if description}}
          <span class="c-home-articles__item-desc">{{excerpt description}}</span>
          {{/if}}
        </a>
        {{/is}}
      {{/each}}

      {{!-- Row 2: Device care and longevity (bottom-left) --}}
      {{#each categories}}
        {{#is id 31678891552274}}
        <a class="c-home-articles__item c-home-articles__item--with-icon" href="{{url}}">
          <div class="c-home-articles__item-icon">
            <img src="{{asset 'svg/lightbulb.svg'}}" alt="">
          </div>
          <h4 class="c-home-articles__item-title">{{name}}</h4>
          {{#if description}}
          <span class="c-home-articles__item-desc">{{excerpt description}}</span>
          {{/if}}
        </a>
        {{/is}}
      {{/each}}

      {{!-- Row 2: Self repair (bottom-right) --}}
      {{#each categories}}
        {{#is id 31678896561170}}
        <a class="c-home-articles__item c-home-articles__item--with-icon" href="{{url}}">
          <div class="c-home-articles__item-icon">
            <img src="{{asset 'svg/build.svg'}}" alt="">
          </div>
          <h4 class="c-home-articles__item-title">{{name}}</h4>
          {{#if description}}
          <span class="c-home-articles__item-desc">{{excerpt description}}</span>
          {{/if}}
        </a>
        {{/is}}
      {{/each}}

    </div>
  </section>

</section>

{{!-- ============================================
  SECTION 4: CONTACT SUPPORT
============================================ --}}
<section class="c-contact-support">
  <div class="c-contact-support__inner">
    <h2 class="c-contact-support__title">{{dc 'support_title'}}</h2>
    
    {{!-- Chat Support - White background card --}}
    <div class="c-contact-card c-contact-card--white">
      <div class="c-contact-card__inner">
        <div class="c-contact-card__icon">
           <img src="{{asset 'svg/chat-bubble.svg'}}" alt="">
        </div>
        <div class="c-contact-card__content">
          <h3 class="c-contact-card__title">{{dc 'support_chat_heading'}}</h3>
          <p class="c-contact-card__text">
            → {{dc 'support_chat_detail_tin_assistant'}}<br>
            → {{dc 'support_chat_detail_live_hours'}}
          </p>
        </div>
        <a href="#" id="chat-with-fairphone" class="c-btn-primary">
          {{dc 'support_button_start_chat'}} →
        </a>
      </div>
    </div>

    {{!-- Email Support - Grey background (no container) --}}
    <div class="c-contact-card c-contact-card--grey">
      <div class="c-contact-card__inner">
        <div class="c-contact-card__icon">
          <img src="{{asset 'svg/email.svg'}}" alt="">
        </div>
        <div class="c-contact-card__content">
          <h3 class="c-contact-card__title">{{dc 'support_email_heading'}}</h3>
          <p class="c-contact-card__text">
            {{dc 'support_email_description'}}
          </p>
        </div>
        <a href="https://support.fairphone.com/hc/en-us/requests/new" class="c-btn-secondary">
          {{dc 'support_button_create_ticket'}} →
        </a>
      </div>
    </div>
  </div>
</section>

{{!-- ADDED FROM PRODUCTION: Zingtree Script (Preserved from Legacy) --}}
<script src="https://zingtree.com/deploy/popup-modal.js"></script>
{{!--
  PRODUCTION TEMPLATE: community_topic_list_page.hbs
  Source: actual_theme/templates/community_topic_list_page.hbs

  REMOVED FROM COPENHAGEN:
  - hero section with search icon SVG and scoped search
  - container with breadcrumbs, community-header (dropdown for topics/posts, new_post button)
  - topics blocks-list with internal icon, description, post_count, follower_count
  - featured_posts section
  - community-activity section
  - community-footer section

  ADDED FROM PRODUCTION:
  - Custom sub-nav with community heading and search
  - Custom community-nav with topics, posts, new_post links
  - Custom community-sub-nav with "All" link
  - Custom topic-list with topics (internal icon, name, post_count, follower_count)
  - Pagination
--}}

<nav class="sub-nav clearfix">
  <h4 class="community-heading">
    {{t 'community'}}
  </h4>
  {{search}}
</nav>

<nav class="community-nav">
  <ul>
    <li>{{t 'topics'}}</li>
    <li>{{link 'posts'}}</li>
    <li>{{link 'new_post' role='button'}}</li>
  </ul>
</nav>

<div class="clearfix">
  <div class="main-column">

    <nav class="community-sub-nav">
      <ul>
        <li>{{t 'all'}}</li>
      </ul>
    </nav>

    {{#if topics}}
      <ul class="topic-list">
        {{#each topics}}
          <li class="topic">
            <h3 class="topic-title">
              {{#if internal}}
                <span class="visibility-internal" data-title="{{t 'internal'}}">
                  <span class="visibility-internal-icon"></span>
                </span>
              {{/if}}
              <a href="{{url}}">{{name}}</a>
            </h3>
            <span class="topic-meta">
              <span>{{t 'post_count' count=post_count}}</span>
              <span>{{t 'follower_count' count=follower_count}}</span>
            </span>
          </li>
        {{/each}}
      </ul>
    {{else}}
      <p>{{t 'no_content'}}</p>
    {{/if}}

    {{pagination}}

  </div>
</div>
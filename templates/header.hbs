{{!--
  Header Fairphone
  - Burger <-> croix : pur CSS (checkbox hack), pas de JS
  - Comportement scroll (hide/sticky/bordure) : voir script.js
  - L'input checkbox doit rester le premier enfant de .site-header-inner
    pour que les sélecteurs de fratrie (~) fonctionnent sur .site-header-left
    (qui contient à la fois .site-nav et le burger .nav-toggle).
--}}
<header class="site-header" id="site-header">
  <div class="site-header-inner">

    <input
      type="checkbox"
      id="nav-toggle"
      class="nav-toggle-input"
      aria-hidden="true"
    >

    <div class="site-header-left">
      <label for="nav-toggle" class="nav-toggle" aria-label="{{t 'toggle_navigation'}}">
        <span class="nav-toggle-icon" aria-hidden="true"></span>
      </label>

      <a href="{{help_center.url}}" class="site-header-logo" aria-label="{{help_center.name}}">
        <span class="site-header-logo-mark" aria-hidden="true"></span>
      </a>

      <nav class="site-nav" id="site-nav" aria-label="{{t 'main_navigation'}}">
        <ul class="site-nav-list">
          <li class="site-nav-item">
            <a href="https://www.fairphone.com/" class="site-nav-link">Shop</a>
          </li>
          <li class="site-nav-item">
            <a href="https://www.fairphone.com/about-us" class="site-nav-link">About</a>
          </li>
          <li class="site-nav-item">
            <a href="https://www.fairphone.com/stories" class="site-nav-link">Fairphone Stories</a>
          </li>
        </ul>

        {{!-- Liens secondaires : repris en bas du menu plein écran mobile --}}
        <ul class="site-nav-list site-nav-list--secondary">
          <li class="site-nav-item">
            <a href="https://www.fairphone.com/keep-club-fairphone" class="site-nav-link site-nav-link--secondary">Keep Club</a>
          </li>
          <li class="site-nav-item">
            <a href="https://www.fairphone.com/business" class="site-nav-link site-nav-link--secondary">Business</a>
          </li>
          <li class="site-nav-item">
            <a href="{{help_center.url}}" class="site-nav-link site-nav-link--secondary">Support</a>
          </li>
        </ul>
      </nav>
    </div>

    <div class="site-header-actions">

      {{!-- Liens secondaires : affichés à gauche de l'icône user sur desktop uniquement --}}
      <ul class="secondary-nav-list">
        <li><a href="https://www.fairphone.com/keep-club-fairphone" class="secondary-nav-link">Keep Club</a></li>
        <li><a href="https://www.fairphone.com/business" class="secondary-nav-link">Business</a></li>
        <li><a href="{{help_center.url}}" class="secondary-nav-link">Support</a></li>
      </ul>

      {{#if signed_in}}
        <div class="user-info">
          <button
            type="button"
            class="user-dropdown-toggle"
            id="user-dropdown-toggle"
            aria-haspopup="true"
            aria-expanded="false"
            aria-controls="user-dropdown-menu"
          >
            {{user_avatar class="user-avatar-icon"}}
            <span class="visually-hidden">{{user_name}}</span>
          </button>
          <ul class="user-dropdown-menu" id="user-dropdown-menu">
            <li>{{link 'my_profile'}}</li>
            <li>{{link 'sign_out'}}</li>
          </ul>
        </div>
      {{else}}
        {{#link "sign_in" class="user-signin-link"}}
          {{user_avatar class="user-avatar-icon"}}
          <span class="visually-hidden">{{t 'sign_in'}}</span>
        {{/link}}
      {{/if}}

    </div>
  </div>
</header>

{{!-- Compense le position:fixed du header pour ne pas faire sauter le contenu --}}
<div class="site-header-spacer" aria-hidden="true"></div>

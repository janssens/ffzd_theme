{{!--
  PRODUCTION TEMPLATE: community_topic_page.hbs
  Source: actual_theme/templates/community_topic_page.hbs

  REMOVED FROM COPENHAGEN:
  - container-divider and container wrapper with breadcrumbs and scoped search
  - page-header with topic name, internal icon, new_post button
  - community-header with description, subscribe
  - topic-header with filters and sorters dropdowns
  - posts-list with striped-list items (SVG icons, status labels, meta, vote/comment counts)
  - community-footer section

  ADDED FROM PRODUCTION:
  - Custom sub-nav with community heading and scoped search
  - Custom community-nav with topics, posts, new_post links
  - Topic header with internal icon, name, follower count, subscribe
  - Topic description
  - Commented-out post status filter snippet
  - Custom community-sub-nav with sorters
  - Custom question-list with posts (title, author, date, votes, comments, status)
  - Pagination
--}}

<nav class="sub-nav clearfix">
  <h4 class="community-heading">{{t 'community'}}</h4>
  {{search scoped=true}}
</nav>

<nav class="community-nav">
  <ul>
    <li>{{link 'topics'}}</li>
    <li>{{link 'posts'}}</li>
    <li>{{link 'new_post' role='button' topic_id=topic.id}}</li>
  </ul>
</nav>

<div class="clearfix">
  <div class="main-column">

    <header class="topic-header">
      <h1 class="topic-heading">
        {{#if topic.internal}}
          <span class="visibility-internal" data-title="{{t 'internal'}}">
            <span class="visibility-internal-icon"></span>
          </span>
        {{/if}}
        {{topic.name}}
      </h1>
      <span class="topic-meta">
        {{t 'follower_count' count=topic.follower_count}}
      </span>
      <span>
        {{subscribe}}
      </span>
    </header>

    <p class="topic-description">{{topic.description}}</p>

    <section class="topic-questions">

      {{!--
      ** NEW COMMUNITY SNIPPET **
      Please uncomment these lines if you want to allow your users to filter posts by status
      <span class="topic-filters">
        <span class="dropdown">
          <span class="dropdown-toggle">
            {{current_filter.label}}
          </span>
          <span class="dropdown-menu" role="menu">
            {{#each filters}}
              <a href="{{url}}" aria-selected="{{selected}}" role="menuitem">
                {{name}}
              </a>
            {{/each}}
          </span>
        </span>
      </span>
      --}}

      <nav class="community-sub-nav">
        <ul>
          {{#each sorters}}
            <li>
              {{#if selected}}
                {{name}}
              {{else}}
                <a href="{{url}}">
                  {{name}}
                </a>
              {{/if}}
            </li>
          {{/each}}
        </ul>
      </nav>
      {{#if posts}}
        <ul class="question-list">
          {{#each posts}}
            <li class="question {{#if has_official_comment}} question-official-answer {{/if}} {{#if featured}} post-featured {{/if}} {{#if pinned}} post-pinned {{/if}}">
              <h3 class="question-title">
                <a href="{{url}}">{{title}}</a>
              </h3>
              <div class="question-meta">
                <span class="question-author">
                  {{#link 'user_profile' id=author.id}}
                    {{author.name}}
                  {{/link}}
                </span>
                <span class="question-published">
                  {{date created_at timeago=true}}
                </span>
                <span class="question-votes">
                  {{vote_sum}} {{t 'vote' count=vote_sum}}
                </span>
                <span class="question-answers">
                  {{comment_count}} {{t 'comment' count=comment_count}}
                </span>
                {{! Show the post status, if any }}
                {{#is status 'none'}}
                {{else}}
                  <span class="post-{{status_dasherized}}">{{status_name}}</span>
                {{/is}}
              </div>
            </li>
          {{/each}}
        </ul>
      {{else}}
        <p>{{t 'no_content'}}</p>
      {{/if}}

      {{pagination}}
    </section>
  </div>
</div>
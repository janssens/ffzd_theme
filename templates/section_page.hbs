{{!--
  PRODUCTION TEMPLATE: section_page.hbs
  Source: actual_theme/templates/section_page.hbs

  REMOVED FROM COPENHAGEN:
  - container-divider and container wrapper
  - sub-nav with breadcrumbs and scoped search
  - section-container with section-content, page-header (subscribe, description)
  - section-list (sub-sections with chevron icons)
  - article-list with promoted/lock SVG icons
  - pagination for sections and articles

  ADDED FROM PRODUCTION:
  - Custom search hero section (c-simple-search)
  - Custom breadcrumbs (c-breadcrumb-wrapper)
  - Custom category content area with title, description, article-list, pagination
  - NOTE: CSS styles moved to SCSS files (breadcrumb, search, category)
--}}

<section class="section-page"> 

  
   {{!-- 2. SEARCH SECTION (Safety net) --}}
  <section class="c-simple-search c-simple-search--white c-simple-search--green">
    <h2 class="c-simple-search__title">{{dc 'hero_title'}}</h2>
    <div class="c-simple-search__form">
      {{search submit=true instant=true placeholder='Search by question, product'}}
    </div>
  </section>
  
  {{!-- 1. BREADCRUMBS (Top) --}}
  <section class="c-breadcrumb-wrapper">
    <div class="c-container">
      {{breadcrumbs}}
    </div>
  </section>
  

<section class="c-category__content page-content">
  <section class="clearfix">
    <h1 class="c-title c-title--center">{{#if section.internal}}
      <span class="visibility-internal" data-title="{{t 'internal'}}">
        <span class="visibility-internal-icon"></span>
      </span>
      {{/if}} {{section.name}}</h1>
    {{#if section.description}}
    <h2 class="c-desc c-desc--center">{{section.description}}</h2>
    {{/if}}

    {{#if section.articles}}
    <div class="c-category__content-tree">
        <ul class="article-list" style="text-align: left;">
          {{#each section.articles}}
          <li {{#if promoted}} class="article-promoted" {{/if}} >
            {{#if promoted}}
            <span data-title="{{t 'promoted'}}">★</span>
            {{/if}}
            <a href="{{url}}">{{title}}</a>
          </li>
          {{/each}}
        </ul>
        {{pagination}}
    </div>
    {{else}}
    <i class="section-empty">
      <a href="#">{{t 'empty'}}</a>
    </i>
    {{/if}}
  </section>
</section>

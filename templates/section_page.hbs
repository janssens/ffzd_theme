{{!--
  PRODUCTION TEMPLATE: section_page.hbs
  Source: actual_theme/templates/section_page.hbs
--}}

<section class="section-page">

  <div class="grid">
    <aside class="section-page-sidebar">
      {{!-- 1. BREADCRUMBS --}}
      <section class="c-breadcrumb-wrapper">
        {{breadcrumbs}}
      </section>

      {{!-- 2. NAV --}}
      <section class="nav">
        {{#if category.sections}}
          <ol>
            {{#each sections}}
              <li >
                  <a href="#section_{{ id }}">{{name}}</a>
              </li>
            {{/each}}
          </ol>
        {{/if}}
      </section>
    </aside>

    <section id="main-content" class="category-page-column">
      

        {{!-- STANDARD LAYOUT — All other categories --}}
        <h1 class="c-category-body-title">{{section.name}}</h1>

        {{#if section.description}}
          <p class="c-desc">{{section.description}}</p>
        {{/if}}

        {{#if section.articles}}
          <div class="c-section__content-tree">
                  <ul class="article-list">
                    {{#each section.articles}}
                      <li {{#if promoted}} class="article-promoted" {{/if}}>
                      <article>
                        <header>
                          <div class="search-result-title-container">
                            <h2 class="search-result-title">
                              <a href="{{url}}">
                                {{#if promoted}}
                                <span data-title="{{t 'promoted'}}">★</span>
                                {{/if}}
                                {{title}}
                              </a>
                            </h2>
                          </div>
                          <div class="search-result-btn-container">
                            <a href="{{url}}" class="">
                              {{t "read_guide"}} →
                            </a>
                          </div>
                          <div class="search-result-meta-container">
                            <nav>
                              <ol class="search-result-breadcrumbs">
                                <li data-type="article"><span>article</span></li>
                                {{#each path_steps}}
                                <li><a href="{{url}}" target="{{target}}">{{name}}</a></li>
                                {{/each}}
                                <li class="meta-data">{{t "updated" }}&nbsp;{{date created_at timeago=true}}</li>
                              </ol>
                            </nav>
                          </div>
                        </header>
                      </article>
                      </li>
                    {{/each}}
                  </ul>
          </div>
        {{/if}}


    </section>
  </div>




<section class="section-page"> 

  

  
  {{!-- 1. BREADCRUMBS (Top) --}}
  <section class="c-breadcrumb-wrapper">
    <div class="c-container">
      {{breadcrumbs}}
    </div>
  </section>
  

<section class="c-category__content page-content">
  <section class="clearfix">
    <h1 class="c-title c-title--center">{{section.name}}</h1>
    {{#if section.description}}
    <h2 class="c-desc c-desc--center">{{section.description}}</h2>
    {{/if}}

    {{#if section.articles}}
    <div class="c-category__content-tree">
        <ul class="article-list" style="text-align: left;">
          {{#each section.articles}}
          <li {{#if promoted}} class="article-promoted" {{/if}} >
            {{#if promoted}}
            <span data-title="{{t 'promoted'}}">★</span>
            {{/if}}
            <a href="{{url}}">{{title}}</a>
          </li>
          {{/each}}
        </ul>
        {{pagination}}
    </div>
    {{else}}
    <i class="section-empty">
      <a href="#">{{t 'empty'}}</a>
    </i>
    {{/if}}
  </section>
</section>

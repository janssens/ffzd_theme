<script>
    $(document).ready(function() {
      Fairphone().start();
    });

    window.addEventListener('DOMContentLoaded', function(){
      var ZingtreeFrame = document.querySelector('iframe[src*="https://zingtree.com/deploy/tree.php"]'); 
      var getQueryVariable = function(variable) {
        var query = document.location.search.substring(1);
        var vars = query.split('&');
        for (var i = 0; i < vars.length; i++) {
          var pair = vars[i].split('=');
          if (pair[0] == variable) {
            return pair[1];
          }
        }
        return '';
      };
      if( ZingtreeFrame ) {
          ZingtreeFrame.onload = function() {
            if( getQueryVariable('session_id') != '' ) {
              ZingtreeFrame.contentWindow.postMessage({
                message: 'FP_ZINGTREE',
                session_id: getQueryVariable('session_id'),
                success: getQueryVariable('success')
              },"*");
            }
        }
      }
    });

    window.addEventListener('message', event => {
      if(event.data.message && event.data.message == 'Successful submission'){
        history.replaceState(
          {},
          document.title,
          top.window.location.href +
            '&success=true'
        );
        window.location.replace(event.data.redirect);
      }
    });

    //zE('messenger', 'hide');

    console.log('Script starting...');

  document.addEventListener('DOMContentLoaded', function() {
      console.log('DOM loaded, looking for chat button...');

      const chatButton = document.getElementById('chat-with-fairphone');
      console.log('Chat button search result:', chatButton);

      if (chatButton) {
          console.log('Chat button found! Adding event listener...');

          chatButton.addEventListener('click', function(e) {
              console.log('BUTTON CLICKED!');
              e.preventDefault();
              e.stopPropagation();

              if (typeof zE !== 'undefined') {
                  console.log('Opening Zendesk...');
                  zE('messenger', 'show');
                  zE('messenger', 'open');
              } else {
                  console.log('zE not available');
              }
          });

          console.log('Event listener added successfully');
      } else {
          console.log('ERROR: Chat button not found!');
      }
  });

  console.log('Script loaded');
</script>

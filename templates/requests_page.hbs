{{!--
  PRODUCTION TEMPLATE: requests_page.hbs
  Source: actual_theme/templates/requests_page.hbs

  REMOVED FROM COPENHAGEN:
  - container wrapper
  - request_list_beta conditional (request_list component)
  - my-activities-header with h1
  - my-activities-sub-nav with collapsible-nav (filters)
  - requests_filter form with search, organization, status
  - requests-search-info
  - requests table with subject, id, created, last_activity, status (with SVG icons)
  - pagination

  ADDED FROM PRODUCTION:
  - Custom search section with "We're here to help" heading (c-simple-search)
  - Custom breadcrumbs
  - my-activities-nav with requests, contributions, subscriptions links
  - my-activities-sub-nav with filters
  - Custom request table with search, organization, status filters
  - Custom table with id, subject, created, last_activity, status columns
  - jQuery-based search on select change and input enter
--}}

<section class="activities-page">
  <section class="c-simple-search c-simple-search--small">
    <h1 class="c-simple-search__title">We're here to help</h1>
    <div class="c-simple-search__form">
      {{search}}
    </div>
    <div class="c-simple-search__breadcrumbs">
      {{breadcrumbs}}
    </div>
  </section>

    <nav class="my-activities-nav">
        <ul>
            <li>{{t 'requests'}}</li>
            <li>{{link 'contributions'}}</li>
            <li>{{link 'subscriptions'}}</li>
        </ul>
    </nav>

    <nav class="my-activities-sub-nav">
        <ul>
            {{#each filters}}
                <li>
                    {{#if selected}}
                        {{name}}
                    {{else}}
                        <a href="{{url}}">{{name}}</a>
                    {{/if}}
                </li>
            {{/each}}
        </ul>
    </nav>

    <div class="c-post-body">
        <h1 class="c-title">My Fairphone Activities</h1>

        <div class="request-table-toolbar">
            {{input 'query' id='quick-search' type='search' class='requests-search'}}
            {{label 'organization' for='request-organization-select' class='request-filter'}}
            {{select 'organization' id='request-organization-select' class='request-filter'}}
            {{label 'status' for='request-status-select' class='request-filter'}}
            {{select 'status' id='request-status-select' class='request-filter'}}
        </div>

        <div class="my-activities-table request-table">
            <script>
                $(document).ready(function () {

                   // Submit search on select change
        $("#request-status-select, #request-organization-select")
          .on("change", function() {
            search();
          });

        // Submit search on input enter
        $("#quick-search").on("keypress", function(e) {
          if (e.which === 13) {
            search();
          }
        });

        function search() {
          window.location.search = $.param({
            query: $("#quick-search").val(),
            status: $("#request-status-select").val(),
            organization_id: $("#request-organization-select").val()
          });
        }

      });
      </script>

            {{#if requests}}
                <table id="request-table" class="request-table {{current_filter.identifier}}-requests">
                    <thead>
                        <tr>
                            <th>{{t 'id'}}</th>
                            <th>{{t 'subject'}}</th>
                            <th>
                                {{#is current_filter.identifier 'my'}}
                                    {{t 'created'}}
                                {{else}}
                                    {{t 'requester'}}
                                {{/is}}
                            </th>
                            <th>{{t 'last_activity'}}</th>
                            <th>{{t 'status'}}</th>
                        </tr>
                    </thead>
                    <tbody>
                        {{#each requests}}
                            <tr>
                                <td>{{id}}</td>
                                <td>
                                    <a href="{{url}}">
                                        {{#if subject}}
                                            {{subject}}
                                        {{else}}
                                            {{excerpt description characters=50}}
                                        {{/if}}
                                    </a>
                                </td>
                                <td>
                                    {{#is ../current_filter.identifier 'my'}}
                                        {{date created_at timeago=true}}
                                    {{else}}
                                        {{requester.name}}
                                    {{/is}}
                                </td>
                                <td>{{date updated_at timeago=true}}</td>
                                <td>
                                    <span class="request-status request-{{status}}" title="{{status_description}}">
                                        {{status_name}}
                                    </span>
                                </td>
                            </tr>
                        {{/each}}
                    </tbody>
                </table>
            {{else}}
                <p>{{t 'no_requests'}}</p>
            {{/if}}

            {{pagination}}
        </div>
    </div>
</section>
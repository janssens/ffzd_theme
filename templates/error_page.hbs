<!-- <section class="c-home-search">
  <div class="c-home-search__content">
    <h1>Page not found...</h1>
    {{search}}
  </div>
</section> -->

<section class="c-simple-search c-simple-search--small">
  <h1 class="c-simple-search__title">Page not found...</h1>
  <div class="c-simple-search__form">
    {{search}}
  </div>
  <div class="c-simple-search__breadcrumbs">
  </div>
</section>

<div class="error-page">
  <h1>{{t 'oops'}}</h1>
  {{#is error 'unauthorized'}}
    <h2>{{link 'sign_in'}}</h2>
  {{/is}}

  {{#is error 'forbidden'}}
    <h2>{{t 'not_authorized'}}</h2>
  {{/is}}

  {{#is error 'not_found'}}
    <h2>{{t 'nonexistent_page'}}</h2>
    <p>{{t 'mistyped_address_or_moved_page'}}</p>
  {{/is}}
  {{#link 'help_center'}}
    {{t 'back_to_homepage'}}
  {{/link}}
</div>
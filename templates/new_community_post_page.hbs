{{!--
  PRODUCTION TEMPLATE: new_community_post_page.hbs
  Source: actual_theme/templates/new_community_post_page.hbs

  REMOVED FROM COPENHAGEN:
  - container-divider and container wrapper with breadcrumbs and scoped search
  - h1 with form-header and what_is_your_post_about
  - Form with title (optional label with optional span), details (optional), topic (optional)
  - content_tags multiselect field with add-hint
  - aria-describedby error notifications

  ADDED FROM PRODUCTION:
  - Custom sub-nav with community heading and search
  - Custom community-nav with topics, posts, new_post links
  - Custom title "What is your post about"
  - Form with title, details, topic (required validation only, no optional labels)
  - Submit button
--}}

<nav class="sub-nav clearfix">
  <h4 class="community-heading">
    {{t 'community_heading'}}
  </h4>
  {{search}}
</nav>

<nav class="community-nav">
  <ul>
    <li>{{link 'topics'}}</li>
    <li>{{link 'posts'}}</li>
    <li>{{link 'new_post' role='button'}}</li>
  </ul>
</nav>

<div class="clearfix">
  <h1>{{t 'what_is_your_post_about'}}</h1>
  <div class="main-column">
    <div class="form">
      {{#form 'post' class='new_community_post'}}
        <div class="form-field {{#required 'title'}}required{{/required}}">
          {{label 'title'}}
          {{input 'title' autofocus=true}}
          {{#validate 'title'}}
            <div class="notification notification-error notification-inline">
              {{error 'title'}}
            </div>
          {{/validate}}
        </div>

        {{suggestion_list class='searchbox'}}

        <div class="form-field {{#required 'details'}}required{{/required}}">
          {{label 'details'}}
          {{wysiwyg 'details'}}
          {{#validate 'details'}}
            <div class="notification notification-error notification-inline">
              {{error 'details'}}
            </div>
          {{/validate}}
        </div>

        <div class="form-field {{#required 'topic'}}required{{/required}}">
          {{label 'topic'}}
          {{select 'topic'}}
          {{#validate 'topic'}}
            <div class="notification notification-error notification-inline">
              {{error 'topic'}}
            </div>
          {{/validate}}
        </div>

        <footer>{{input type='submit'}}</footer>
      {{/form}}
    </div>
  </div>
</div>
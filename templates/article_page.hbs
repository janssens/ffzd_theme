{{!--
  PRODUCTION TEMPLATE: article_page.hbs
  Source: actual_theme/templates/article_page.hbs

  REMOVED FROM COPENHAGEN:
  - container-divider and container wrapper
  - sub-nav with breadcrumbs and scoped search
  - article-sidebar with section articles list (collapsible sidebar)
  - article-header with author, dates, subscribe
  - article-info with content_tags, attachments (with SVG icons)
  - article-footer with share, comments, votes, request_callout, return_to_top
  - article-relatives (recently_viewed, related)
  - article-comments section with comment list, form, pagination

  ADDED FROM PRODUCTION:
  - Custom search hero section (c-simple-search)
  - Custom breadcrumbs (c-breadcrumb-wrapper)
  - Post body layout (c-post-body) with flex layout
  - Custom title with internal icon
  - Article body, attachments, share buttons (Facebook, LinkedIn)
  - Feedback section with external survey link
  - Sidebar with related_articles only
  - NOTE: CSS styles moved to SCSS files (breadcrumb, article, search, buttons)
--}}

<section class="article-page">
      

    {{!-- 1. BREADCRUMBS --}}
  <section class="c-breadcrumb-wrapper">
    <div class="c-container">
      {{breadcrumbs}}
    </div>
  </section>
  

  <div class="c-post-body">
    {{!-- MAIN CONTENT --}}
    
    <div class="main-content {{#is article.id 360019253412}}c-android-article{{/is}} {{#is article.id 115001041206}}c-troubleshoter-article{{/is}}">
      <h1 class="c-title">
        {{#if article.internal}}
          <span class="visibility-internal" data-title="{{t 'internal'}}">
            <span class="visibility-internal-icon"></span>
          </span>
        {{/if}}
        {{article.title}}
      </h1>

      <div class="article-body">
        {{article.body}}
      </div>

      {{#if attachments}}
        <div class="article-attachments">
          <ul class="attachments">
            {{#each attachments}}
              <li>
                <a href="{{url}}" target="_blank">{{name}}</a>
                <span>({{size}})</span>
              </li>
            {{/each}}
          </ul>
        </div>
      {{/if}}

      <div class="article-footer">
        <div id="share">
          <ul class="share">
            <li><a href="https://www.facebook.com/share.php?title=Fairphone%27s+Brand+Identity&u=https%3A%2F%2Fsupport.fairphone.com%2Fhc%2Fen-us%2Farticles%2F23478616310034-Fairphone-s-Brand-Identity" class="share-facebook" id="share-fb" class="share-facebook">Facebook</a></li>
            <li><a href="https://www.linkedin.com/shareArticle?mini=true&source=Fairphone&title=Fairphone%27s+Brand+Identity&url=https%3A%2F%2Fsupport.fairphone.com%2Fhc%2Fen-us%2Farticles%2F23478616310034-Fairphone-s-Brand-Identity" id="share-li" class="share-linkedin">LinkedIn</a></li>
          </ul>
        </div>

        <script>
          (function() {
            var pageUrl = encodeURIComponent("{{article.url}}");
            var fbLink = document.getElementById('share-fb');
            var liLink = document.getElementById('share-li');
            if (fbLink) fbLink.setAttribute('href', 'https://www.facebook.com/share.php?u=' + pageUrl);
            if (liLink) liLink.setAttribute('href', 'https://www.linkedin.com/shareArticle?mini=true&url=' + pageUrl);
          })();
        </script>
        
        <div id="article-feedback">
          <h3 class="c-feedback-title">How helpful was this article?</h3>
          <a href="https://fairphone.survey.hellocustomer.com/EN/a187c143-4462-4b09-86a1-6ac7ef4aada4/30ef2b77-6d06-47c7-878c-bc012681639c/0563f601-eb9b-4901-a09f-5fdd5ce95835" id="feedback-link" class="c-btn-secondary">
            Give feedback →
          </a>
        </div>
      </div>
    </div>

    {{!-- SIDEBAR: Now stacks to bottom on mobile --}}
    <aside class="article-sidebar">
      {{#if related_articles}}
        <div class="related-articles-block">
          {{related_articles}}
        </div>
      {{/if}}
    </aside>
  </div>

</section>
